{
  "name": "jock-git-client",
  "private": true,
  "version": "0.1.9",
  "author": {
    "name": "Praetor Dev",
    "email": "dev@praetordev.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "npx @electron/rebuild -f -w node-pty",
    "dev": "bash scripts/build-backend.sh && bash scripts/build-vex.sh && ELECTRON_RUN_AS_NODE= vite --port=3000",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "backend:build": "bash scripts/build-backend.sh",
    "backend:proto": "bash scripts/generate-proto.sh",
    "electron:build": "bash scripts/build-backend.sh && bash scripts/build-vex.sh && ELECTRON_RUN_AS_NODE= vite build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.jock.gitide",
    "productName": "Jock",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/bin/",
        "to": "bin",
        "filter": [
          "jockd",
          "jockq",
          "jockmcp",
          "vex"
        ]
      },
      {
        "from": "proto/",
        "to": "proto",
        "filter": [
          "*.proto"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "praetordev",
      "repo": "jockv2"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  }
}
